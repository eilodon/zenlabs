{
    "name": "zenone-app",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "start": "cd app && npm start",
        "ios": "cd app && npm run ios",
        "android": "cd app && npm run android",
        "build:rust:ios": "cd rust-core && cargo build --target aarch64-apple-ios --release",
        "build:rust:android": "cd rust-core && cargo ndk -t arm64-v8a build --release"
    }
}