# ZenOne Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# GOOGLE OAUTH CONFIGURATION
# ============================================================================
# Get these from: https://console.cloud.google.com/apis/credentials
#
# Instructions:
# 1. Go to Google Cloud Console
# 2. Create a new project or select existing one
# 3. Enable Google Sign-In API
# 4. Create OAuth 2.0 credentials for each platform
# 5. Copy the client IDs here

# Web Client ID (for web platform)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS Client ID (for iOS platform)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android Client ID (for Android platform)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ============================================================================
# BACKEND API CONFIGURATION (Future)
# ============================================================================
# When you have a backend API, add these:

# API Base URL
# EXPO_PUBLIC_API_BASE_URL=https://api.zenone.app

# API Key (if needed)
# EXPO_PUBLIC_API_KEY=your-api-key-here

# ============================================================================
# WEARABLE INTEGRATIONS (Future)
# ============================================================================
# When integrating wearable APIs, add these:

# Zepp Health API (Xiaomi/Mi Band)
# EXPO_PUBLIC_ZEPP_API_KEY=your-zepp-api-key
# EXPO_PUBLIC_ZEPP_API_SECRET=your-zepp-api-secret

# Fitbit API
# EXPO_PUBLIC_FITBIT_CLIENT_ID=your-fitbit-client-id
# EXPO_PUBLIC_FITBIT_CLIENT_SECRET=your-fitbit-client-secret

# Garmin Connect IQ
# EXPO_PUBLIC_GARMIN_CONSUMER_KEY=your-garmin-consumer-key
# EXPO_PUBLIC_GARMIN_CONSUMER_SECRET=your-garmin-consumer-secret

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
# If you want to add analytics:

# Google Analytics
# EXPO_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (Error tracking)
# EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================
# Enable/disable features:

# Enable camera-based heart rate detection
# EXPO_PUBLIC_ENABLE_CAMERA_HR=true

# Enable wearable integration
# EXPO_PUBLIC_ENABLE_WEARABLES=true

# Enable social features (leaderboard)
# EXPO_PUBLIC_ENABLE_SOCIAL=false
